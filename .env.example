# Backend configuration. Store actual secrets only in the untracked .env file on the server.
APP_ENV=production
APP_URL=https://itonai.ro
BASE_PATH=/wp/lefimovart

DB_HOST=localhost
DB_NAME=lefimovart
DB_USER=
DB_PASS=

JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_ENDPOINT_SECRET=
STRIPE_PRICE_BRONZE=
STRIPE_PRICE_SILVER=
STRIPE_PRICE_GOLD=
STRIPE_PRICE_DIAMOND=
STRIPE_PRICE_RHODIUM=

# OpenAI is used for image generation and AI image editing.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5

# FAL.ai is used only for video generation.
FAL_AI_API_KEY=
