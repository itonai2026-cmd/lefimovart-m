# Backend configuration. Store actual secrets only in the untracked .env file on the server.
APP_ENV=production
APP_URL=https://itonai.ro
BASE_PATH=/wp/lefimovart

DB_HOST=localhost
DB_NAME=lefimovart
DB_USER=
DB_PASS=

JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_ENDPOINT_SECRET=
STRIPE_PRICE_BRONZE=
STRIPE_PRICE_SILVER=
STRIPE_PRICE_GOLD=
STRIPE_PRICE_DIAMOND=
STRIPE_PRICE_RHODIUM=

# Google Play Billing is used by the Android wrapper app for consumable credit packs.
GOOGLE_PLAY_PACKAGE_NAME=ro.itonai.lefimovart
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=
GOOGLE_PLAY_PRODUCT_BRONZE=credits_bronze
GOOGLE_PLAY_PRODUCT_SILVER=credits_silver
GOOGLE_PLAY_PRODUCT_GOLD=credits_gold
GOOGLE_PLAY_PRODUCT_DIAMOND=credits_diamond
GOOGLE_PLAY_PRODUCT_RHODIUM=credits_rhodium

# OpenAI is only used as a fallback when Fal.ai image generation/editing fails.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5

# FAL.ai is the primary provider for image generation/editing and video generation.
DEFAULT_IMAGE_MODEL=flux_dev
FAL_AI_API_KEY=
